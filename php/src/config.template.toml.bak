# Reticulum-php — HTTP Exchange Router
# Copy this to config.toml and adjust for your deployment.
#
# All interfaces (Python PostInterface, JS HttpExchangeInterface, etc.)
# register dynamically via HTTP — no pre-configuration needed.

[storage]
sqlite_path = "${project_root}/var/reticulum-php.sqlite"
log_path = "${project_root}/var/router.log"

# The public URL where this node is reachable
host_url = "https://your-node.example.com/reticulum"

[http]
idle_exchange_interval_ms = 1000
max_batch_packets = 64
max_packet_bytes = 512

[maintenance]
interface_stale_after_seconds = 15
batch_ttl_seconds = 86400
packet_hash_ttl_seconds = 86400
path_request_tag_ttl_seconds = 86400
reverse_path_ttl_seconds = 480
link_transport_ttl_seconds = 900

[transport]
rns_mtu = 500
pathfinder_max_hops = 128
path_expiry_default_seconds = 604800
path_expiry_access_point_seconds = 86400
path_expiry_roaming_seconds = 21600
max_random_blobs = 64

# ── PostInterface peers ──────────────────────────────────────────────────
# Connect this Reticulum-post node to another Reticulum-post node over HTTP.
# Each [[PostInterface]] block registers this node as an interface on the
# remote and exchanges packets during request/response cycles.
#
# Poll mode (no wake_url): this node calls /v1/interfaces/exchange on the
#   remote during each incoming HTTP request to fetch queued packets.
# Wake mode (wake_url present): the remote sends POST /v1/wake to the
#   configured wake_url when it has queued packets for this node. The wake
#   handler triggers an immediate exchange back to the remote.
#
# [interfaces]
#
# [[Peer Node (poll mode)]]
# type = PostInterface
# enabled = yes
# node_url = "https://other-node.example.com/reticulum"
# bitrate = 62500
# mtu = 500
#
# [[Peer Node (wake mode)]]
# type = PostInterface
# enabled = yes
# node_url = "https://other-node.example.com/reticulum"
# wake_url = "https://this-node.example.com/reticulum"
# bitrate = 62500
# mtu = 500
